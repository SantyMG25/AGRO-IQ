# AgroIQ Backend Configuration
# Copy this file to .env and fill with your actual values

# ========== LLM Provider ==========
# Options: "azure" or "claude" (default: "azure")
LLM_PROVIDER=azure

# ========== Azure OpenAI Configuration ==========
# Leave empty to use fallback static responses
AZURE_OPENAI_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_DEPLOYMENT_NAME=gpt-4
AZURE_API_VERSION=2024-02-15-preview

# ========== Anthropic Claude Configuration ==========
# Leave empty to use fallback static responses
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-opus-20240229

# ========== Database Configuration ==========
# Database URL for SQLAlchemy
DATABASE_URL=sqlite:///./agro_iq.db

# ========== Server Configuration ==========
# FastAPI host and port
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ========== Frontend URL (for CORS) ==========
FRONTEND_URL=http://localhost:3000

# ========== Development Mode ==========
# Set to "true" for development (more logging, auto-reload)
DEBUG=false
