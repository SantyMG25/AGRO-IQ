# ========== LOCAL DEVELOPMENT CONFIGURATION ==========
# This file uses fallback static LLM responses (no API calls)
# Useful for testing without API costs

# Use fallback mode (no real LLM calls)
LLM_PROVIDER=fallback

# Fake credentials (won't be used)
AZURE_OPENAI_KEY=mock-key-xxxxx
AZURE_OPENAI_ENDPOINT=https://mock.openai.azure.com/
AZURE_DEPLOYMENT_NAME=gpt-4

# Database
DATABASE_URL=sqlite:///./agro_iq.db

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:3000

# Development mode
DEBUG=true
